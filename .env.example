# 1. Token from @BotFather
BOT_TOKEN=put_your_bot_token_here

# 1.1 Yandex SpeechKit for voice message transcription
YANDEX_API_KEY=put_your_yandex_api_key_here
YANDEX_FOLDER_ID=put_your_yandex_folder_id_here

# Optional: use OpenAI instead of Yandex only if you set VOICE_TRANSCRIBER=openai
OPENAI_API_KEY=put_your_openai_api_key_here
VOICE_TRANSCRIBER=yandex

# 2. Your Telegram IDs. Use /whoami in the bot to find them.
ASSISTANT_IDS=123456789
MANAGER_IDS=987654321

# 3. SQLite database file
DATABASE_PATH=assistant_tasks.db

# 4. Reminder settings
REMINDER_AFTER_MINUTES=60
DIGEST_HOUR=9
DIGEST_MINUTE=0
